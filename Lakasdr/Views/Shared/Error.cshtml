@model ErrorViewModel
@{
    ViewData["Title"] = "Hiba";
}

<section class="hero-card reveal">
    <span class="hero-badge">Hibaoldal</span>
    <h1 class="section-title text-danger">Valami hiba történt.</h1>
    <p class="section-subtitle">A kérés feldolgozása közben hiba lépett fel.</p>
</section>

<section class="content-card mt-4 reveal">
    @if (Model.ShowRequestId)
    {
        <p><strong>Request ID:</strong> <code>@Model.RequestId</code></p>
    }

    <p class="mb-0 text-muted-custom">
        Fejlesztői környezetben részletesebb hibainformáció jelenhet meg. Éles környezetben ezt érdemes kikapcsolva tartani.
    </p>
</section>
