<!DOCTYPE html>
<html lang="hu">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Lakás Doktor Hungary Kft.</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Lakasdr.styles.css" asp-append-version="true" />
</head>
<body>
    <div class="page-shell">
        <div class="page-overlay"></div>

        <header class="site-header">
            <div class="container py-3">
                <nav class="navbar navbar-expand-lg custom-navbar">
                    <div class="container-fluid px-0">
                        <a class="navbar-brand d-flex align-items-center gap-3" asp-area="" asp-controller="Home" asp-action="Index">
                            <img src="~/images/logo.png" alt="Lakás Doktor logó" class="brand-logo" />
                            <div>
                                <span class="brand-title">Lakás Doktor</span>
                                <span class="brand-subtitle">Hungary Kft.</span>
                            </div>
                        </a>

                        <button class="navbar-toggler custom-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar" aria-controls="mainNavbar" aria-expanded="false" aria-label="Navigáció megnyitása">
                            <span class="navbar-toggler-icon"></span>
                        </button>

                        <div class="collapse navbar-collapse" id="mainNavbar">
                            <ul class="navbar-nav ms-auto align-items-lg-center gap-lg-2">
                                <li class="nav-item"><a class="nav-pill" asp-controller="Home" asp-action="Index">Főoldal</a></li>
                                <li class="nav-item"><a class="nav-pill" asp-controller="Home" asp-action="Bemutatkozas">Bemutatkozás</a></li>
                                <li class="nav-item"><a class="nav-pill" asp-controller="Home" asp-action="Calculator">Kalkulátor</a></li>
                                <li class="nav-item"><a class="nav-pill" asp-controller="Home" asp-action="Munkatars">Munkatársak</a></li>
                                <li class="nav-item"><a class="nav-pill" asp-controller="Home" asp-action="Ertekeles">Értékelések</a></li>
                                <li class="nav-item"><a class="nav-pill" asp-controller="Home" asp-action="Gallery">Galéria</a></li>
                                <li class="nav-item"><a class="nav-pill nav-pill-outline" asp-controller="Admin" asp-action="Admin">Admin</a></li>
                            </ul>
                        </div>
                    </div>
                </nav>
            </div>
        </header>

        <div class="container">
            <main role="main" class="main-content">
                @RenderBody()
            </main>
        </div>

        <footer class="site-footer">
            <div class="container footer-content">
                <div>
                    <h5>Lakás Doktor Hungary Kft.</h5>
                    <p>Megbízható kivitelezés, modern megjelenés, átlátható ügyfélélmény.</p>
                </div>
                <div class="footer-links">
                    <a class="footer-button" asp-controller="Home" asp-action="Privacy">Adatkezelés</a>
                    <a class="footer-button" asp-controller="Home" asp-action="Gallery">Galéria</a>
                    <a class="footer-button" asp-controller="Home" asp-action="Calculator">Árkalkulátor</a>
                </div>
            </div>
        </footer>
    </div>

    <div class="modal fade" id="loginModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content app-modal">
                <div class="modal-header @(ViewBag.LoginStatus == "success" ? "bg-success text-white" : "bg-danger text-white") border-0">
                    <h5 class="modal-title">@(ViewBag.LoginStatus == "success" ? "Sikeres bejelentkezés" : "Hiba")</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body py-4">
                    @(ViewBag.LoginStatus == "success" ? "Sikeresen bejelentkeztél!" : "Hibás felhasználónév vagy jelszó!")
                </div>
                <div class="modal-footer border-0 pt-0">
                    <button type="button" class="btn btn-primary" data-bs-dismiss="modal">Rendben</button>
                </div>
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)

    <meta name="viewport" content="width=device-width, initial-scale=1.0">
</body>
</html>
