@model Lakasdr.Models.Workers
@{
    ViewData["Title"] = "Új dolgozó";
}

<section class="hero-card reveal">
    <span class="hero-badge">Admin</span>
    <h2 class="section-title">Új dolgozó hozzáadása</h2>
</section>

<section class="form-card mt-4 reveal">
    <form asp-action="NewWorkers" asp-controller="Admin" method="post" class="inline-form">
        <div>
            <label asp-for="Name">Név</label>
            <input asp-for="Name" class="form-control" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>

        <div>
            <label asp-for="WorkId">Munka azonosító</label>
            <input asp-for="WorkId" class="form-control" type="number" />
            <span asp-validation-for="WorkId" class="text-danger"></span>
        </div>
        <div>
            <label asp-for="Exp">Tapasztalat</label>
            <input asp-for="Exp" class="form-control" type="number"/>
            <span asp-validation-for="Exp" class="text-danger"></span>
        </div>

        <div class="action-row">
                <button type="submit" class="btn btn-primary">Mentés</button>
            <a asp-action="WorkersUpdate" class="btn btn-secondary">Mégse</a>
        </div>
    </form>
</section>
