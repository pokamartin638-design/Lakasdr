@{
    ViewData["Title"] = "Admin bejelentkezés";
}

<section class="hero-card reveal">
    <span class="hero-badge">Védett felület</span>
    <h2 class="section-title">Admin bejelentkezés</h2>
    <p class="section-subtitle">Lépjen be a tartalomkezelő felületre az oldal adminisztrációjához.</p>
</section>

<section class="form-card mt-4 reveal" style="max-width: 680px; margin-inline: auto;">
    <form asp-action="Admin" method="post" class="inline-form">
        <div>
            <label for="username">Felhasználónév</label>
            <input name="username" id="username" class="form-control" />
        </div>

        <div>
            <label for="password">Jelszó</label>
            <input name="password" id="password" type="password" class="form-control" />
        </div>

        <div class="action-row">
            <button type="submit" class="btn btn-primary">Bejelentkezés</button>
            <a asp-controller="Home" asp-action="Index" class="btn btn-secondary">Vissza a főoldalra</a>
        </div>
    </form>
</section>

@if (ViewBag.LoginStatus != null)
{
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            var myModal = new bootstrap.Modal(document.getElementById('loginModal'));
            myModal.show();
        });
    </script>
}
