@model Lakasdr.Models.Workers
@using Lakasdr.Models
@{
    ViewData["Title"] = "Dolgozó szerkesztése";
    var jobs = ViewBag.Jobs as List<Jobs>;
}

<section class="hero-card reveal">
    <span class="hero-badge">Admin</span>
    <h2 class="section-title">Dolgozó szerkesztése</h2>
</section>

<section class="form-card mt-4 reveal">
    <form asp-action="WorkersSzerkesztes" method="post" class="inline-form">
        <input asp-for="Id" type="hidden" />

        <div asp-validation-summary="All" class="text-danger"></div>

        <div>
            <label asp-for="Name">Név</label>
            <input asp-for="Name" class="form-control" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>

        <div>
            <label asp-for="WorkId">Munka</label>
            <select asp-for="WorkId" class="form-control">
                <option value="">-- Válassz munkát --</option>
                @if (jobs != null)
                {
                    foreach (var job in jobs)
                    {
                        <option value="@job.Id">@job.Name</option>
                    }
                }
            </select>
            <span asp-validation-for="WorkId" class="text-danger"></span>
        </div>

        <div>
            <label asp-for="Exp">Tapasztalat</label>
            <input asp-for="Exp" class="form-control" type="number" />
            <span asp-validation-for="Exp" class="text-danger"></span>
        </div>

        <div class="action-row">
            <button type="submit" class="btn btn-primary">Mentés</button>
            <a asp-action="WorkersUpdate" class="btn btn-secondary">Mégse</a>
        </div>
    </form>
</section>

<partial name="_ValidationScriptsPartial" />