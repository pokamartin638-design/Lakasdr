@model IEnumerable<Workers>
@{
    ViewData["Title"] = "Dolgozók kezelése";
}

<section class="hero-card reveal">
    <span class="hero-badge">Admin</span>
    <h2 class="section-title">Dolgozók szerkesztése</h2>
    <p class="section-subtitle">Áttekinthető táblázat, akciógombokkal és egységes admin stílussal.</p>
</section>

<section class="table-card mt-4 reveal">
    <div class="action-row mb-3">
        <a asp-action="NewWorkers" asp-controller="Admin" class="btn btn-primary">Új dolgozó hozzáadása</a>
    </div>

    <table class="app-table">
        <thead>
            <tr>
                <th>Azonosító</th>
                <th>Név</th>
                <th>Jelenlegi munka</th>
                <th>Tapasztalat</th>
                <th>Művelet</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var worker in Model)
            {
                <tr>
                    <td>@worker.Id</td>
                    <td>@worker.Name</td>
                    <td>@worker.WorkId</td>
                    <td>@worker.Exp</td>
                    <td>
                        <a asp-action="WorkersSzerkesztes" asp-controller="Admin" asp-route-id="@worker.Id" class="btn btn-secondary">Szerkesztés</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</section>
