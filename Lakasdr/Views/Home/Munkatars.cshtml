@model Lakasdr.Models.Workers
@{
    ViewData["Title"] = "Munkatársak";
    var workers = ViewBag.Workers as List<Lakasdr.Models.Workers>;
}

<section class="hero-card reveal">
    <span class="hero-badge">Csapatunk</span>
    <h2 class="section-title">Munkatársaink</h2>
    <p class="section-subtitle">Ismerje meg a csapat tagjait, és tekintse meg, milyen munkákon dolgoznak.</p>
</section>

<section class="table-card mt-4 reveal">
    <table class="app-table">
        <thead>
            <tr>
                <th>Azonosító</th>
                <th>Név</th>
                <th>Aktuális munka</th>
                <th>Tapasztalat</th>
                <th>Művelet</th>
            </tr>
        </thead>
        <tbody>
            @if (workers != null)
            {
                @foreach (var worker in workers)
                {
                    <tr>
                        <td>@worker.Id</td>
                        <td>@worker.Name</td>
                        <td>@worker.Jobs?.Name</td>
                        <td>@worker.Exp év</td>
                        <td>
                            <a asp-action="Munkatars" asp-controller="Home" asp-route-id="@worker.Id" class="btn btn-secondary">Részletek</a>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</section>

@if (Model != null)
{
    <section class="content-card mt-4 reveal">
        <span class="tag">Kiválasztott munkatárs</span>
        <h3 class="mt-3">@Model.Name</h3>
        <p class="text-muted-custom">Tapasztalat: @Model.Exp év</p>
        <div class="action-row">
            <a asp-action="Munkatekintes" asp-controller="Home" asp-route-id="@Model.WorkId" class="btn btn-primary">Munka megtekintése</a>
            <a asp-action="Index" asp-controller="Home" class="btn btn-secondary">Vissza a főoldalra</a>
        </div>
    </section>
}
