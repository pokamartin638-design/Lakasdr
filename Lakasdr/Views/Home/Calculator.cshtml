@{
    ViewData["Title"] = "Munka kalkulátor";
}

<section class="hero-card reveal">
    <span class="hero-badge">Árajánlat becslés</span>
    <h2 class="section-title">Munka számológép</h2>
    <p class="section-subtitle">
        Gyorsan és átláthatóan kiszámolhatja a várható munkadíjat és anyagköltséget.
    </p>
</section>

<section class="form-card mt-4 reveal">
    <form method="post" class="inline-form" asp-action="Kiszamol">
        <div>
            <label for="kategoria">Válassza ki a munka típusát</label>
            <select name="kategoria" id="kategoria" class="form-select">
                <option value="1">Szobafestés</option>
                <option value="2">Csempézés</option>
                <option value="3">Parkettázás</option>
                <option value="4">Tapétázás</option>
                <option value="5">Burkolás, vakolás</option>
                <option value="7">Vízvezeték javítás</option>
            </select>
        </div>


        @if (ViewBag.Hiba != null)
        {
            <div class="alert alert-danger mt-3">
                @ViewBag.Hiba
            </div>
        }
       
        <div id="teruletDiv">
            <label for="terulet">Munkaterület nagysága (m²)</label>
            <input type="number" name="terulet" id="terulet" class="form-control" />
        </div>

       
        <div id="vizDiv" style="display:none;">
            <label for="vizTipus">Munka típusa</label>
            <select name="vizTipus" id="vizTipus" class="form-select">
                <option value="1">Csap javítás</option>
                <option value="2">Csőcsere</option>
                <option value="3">Duguláselhárítás</option>
            </select>


            <label class="mt-2">Mennyiség (db)</label>
            <input type="number" name="munkaDb" class="form-control" />
        </div>

        <div class="action-row">
            <input type="submit" asp-action="Kiszamol" value="Kiszámolás" class="btn btn-primary" />
            <a asp-action="Letoltes" class="btn btn-secondary">Munkák listája</a>
        </div>
    </form>

   


    

    @if (ViewBag.Osszeg != null)
    {
        <div class="info-banner mt-4">
            <span class="tag">Becsült összeg</span>
            <h3 class="mt-3 mb-1">
                @ViewBag.Osszeg Ft
            </h3>
            <p class="mb-0 text-muted-custom">Az összeg tájékoztató jellegű, anyagárat és munkadíjat tartalmaz.</p>
        </div>
    }
</section>


<script>
    const select = document.getElementById("kategoria");
    const teruletDiv = document.getElementById("teruletDiv");
    const vizDiv = document.getElementById("vizDiv");
  

    function toggleFields() {
        if (select.value == "7") {
            teruletDiv.style.display = "none";
            vizDiv.style.display = "block";
          
        } else {
            teruletDiv.style.display = "block";
            vizDiv.style.display = "none";
      

         
        }
    }

    select.addEventListener("change", toggleFields);
    document.addEventListener("DOMContentLoaded", toggleFields);
</script>
