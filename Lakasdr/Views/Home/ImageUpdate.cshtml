@model List<Lakasdr.Models.Image>
@{
    ViewData["Title"] = "Képkezelés";
}

<section class="hero-card reveal">
    <span class="hero-badge">Admin galéria</span>
    <h2 class="section-title">Kép feltöltése és törlése</h2>
    
</section>

<div class="row g-4 mt-1">
    <div class="col-lg-6 reveal">
        <section class="form-card h-100">
            <h3 class="mb-3">Új kép feltöltése</h3>
            <form asp-action="Upload" method="post" enctype="multipart/form-data" class="inline-form">
                <div>
                    <label for="neve">Kép neve</label>
                    <input type="text" name="nev" placeholder="Például: Fürdőszoba felújítás" id="neve" class="form-control" />
                </div>
                <div>
                    <label for="file">Kép kiválasztása</label>
                    <input type="file" name="file" id="file" class="form-control" />
                </div>
                <div class="action-row">
                    <button type="submit" class="btn btn-primary">Feltöltés</button>
                </div>
            </form>
        </section>
    </div>

    <div class="col-lg-6 reveal">
        <section class="form-card h-100">
            <h3 class="mb-3">Kép törlése név alapján</h3>
            <form asp-action="DeleteByName" method="post" class="inline-form">
                @Html.AntiForgeryToken()
                <div>
                    <label for="torolneve">Törlendő kép neve</label>
                    <input type="text" name="nev_delete" placeholder="Adja meg a kép nevét" id="torolneve" class="form-control" />
                </div>
                <div class="action-row">
                    <button type="submit" class="btn btn-danger">Törlés</button>
                </div>
            </form>

            @if (TempData["Success"] != null)
            {
                <div class="info-banner mt-4">
                    @TempData["Success"]
                </div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="info-banner mt-4" style="border-left: 5px solid #b32041;">
                    @TempData["Error"]
                </div>
            }
        </section>
    </div>
</div>


<section class="table-card mt-4 reveal">
    <h3 class="mb-3">Feltöltött képek</h3>

    @if (Model != null && Model.Any())
    {
        <table class="app-table">
            <thead>
                <tr>
                    <th>Kép</th>
                    <th>Név</th>
                    <th>Útvonal</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            <img src="@item.FilePath" alt="@item.Nev"
                                 style="width:120px;height:80px;object-fit:cover;border-radius:12px;" />
                        </td>
                        <td>@item.Nev</td>
                        <td>@item.FilePath</td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <p>Nincs még feltöltött kép.</p>
    }
</section>
