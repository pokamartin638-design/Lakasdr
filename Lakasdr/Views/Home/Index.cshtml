@{
    ViewData["Title"] = "Főoldal";
}

<section class="hero-card hero-home reveal">
    <div class="row align-items-center g-4">
        <div class="col-lg-7">
            <span class="hero-badge">Építőipari szolgáltatások</span>
            <h1 class="section-title">Megbízható kivitelezés, megbízható csapat!</h1>
            <p class="lead-text">
                A Lakás Doktor Kft. megbízható partner minden lakásfelújítási munkában, legyen szó kisebb átalakításról vagy teljes körű renoválásról. 
                Szakértő csapatunk precíz kivitelezéssel és modern megoldásokkal segít megvalósítani ügyfeleink elképzeléseit. Fontos számunkra a minőség,
                a határidők betartása és az ügyfélközpontú hozzáállás. Bízza ránk otthona megújítását, és mi új életet adunk neki!

            </p>
            <div class="action-row">
                <a asp-controller="Home" asp-action="Bemutatkozas" class="btn btn-primary">Cégbemutató</a>
                <a asp-controller="Home" asp-action="Calculator" class="btn btn-light">Árkalkulátor</a>
                <a asp-controller="Home" asp-action="Gallery" class="btn btn-secondary">Galéria megnyitása</a>
            </div>
        </div>
        <div class="col-lg-5">
            <div class="hero-logo-panel">
                <img src="~/images/logo.png" alt="Lakás Doktor logó" />
            </div>
        </div>
    </div>
</section>

<section class="content-card mt-4 reveal">
    <div class="metrics-grid">
        <div class="metric-card">
            <div class="metric-value">Teljes körű</div>
            <div class="metric-label">Lakásfelújítás egy kézből</div>
        </div>
        <div class="metric-card">
            <div class="metric-value">Precíz munka</div>
            <div class="metric-label">Minőségi kivitelezés</div>
        </div>
        <div class="metric-card">
            <div class="metric-value">Rugalmas</div>
            <div class="metric-label">Ügyfélközpontú hozzáállás</div>
        </div>
        <div class="metric-card">
            <div class="metric-value">Gyors kivitelezés</div>
            <div class="metric-label">Tartjuk a határidőket</div>
        </div>
    </div>
</section>

<section class="mt-4 feature-grid reveal">
    <article class="feature-item">
        <span class="tag">Folyamat</span>
        <h3 class="mt-3">Átlátható folyamat</h3>
        <p class="text-muted-custom mb-0">A felméréstől az átadásig minden lépést világosan kommunikálunk.</p>
    </article>
    <article class="feature-item">
        <span class="tag">Anyag</span>
        <h3 class="mt-3">Minőségi anyagok</h3>
        <p class="text-muted-custom mb-0">Csak bevált, tartós alapanyagokkal dolgozunk.</p>
    </article>
    <article class="feature-item">
        <span class="tag">Csapat</span>
        <h3 class="mt-3">Megbízható csapat</h3>
        <p class="text-muted-custom mb-0">Tapasztalt szakembereink precíz munkát végeznek.</p>
    </article>
</section>
