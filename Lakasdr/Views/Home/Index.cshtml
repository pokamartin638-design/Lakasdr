@{
    ViewData["Title"] = "Főoldal";
}

<section class="hero-card hero-home reveal">
    <div class="row align-items-center g-4">
        <div class="col-lg-7">
            <span class="hero-badge">Építőipari szolgáltatások modern megjelenéssel</span>
            <h1 class="section-title">Megbízható kivitelezés, igényes online arculat.</h1>
            <p class="lead-text">
                A Lakás Doktor Hungary Kft. weboldalának kezdőoldala most egy letisztult, prémium hangulatú,
                kék-fehér vizuális világot kapott. A cél: professzionális első benyomás, könnyű navigáció és
                bizalomépítő megjelenés.
            </p>
            <div class="action-row">
                <a asp-controller="Home" asp-action="Bemutatkozas" class="btn btn-primary">Cégbemutató</a>
                <a asp-controller="Home" asp-action="Calculator" class="btn btn-light">Árkalkulátor</a>
                <a asp-controller="Home" asp-action="Gallery" class="btn btn-secondary">Galéria megnyitása</a>
            </div>
        </div>
        <div class="col-lg-5">
            <div class="hero-logo-panel">
                <img src="~/images/logo.png" alt="Lakás Doktor logó" />
            </div>
        </div>
    </div>
</section>

<section class="content-card mt-4 reveal">
    <div class="metrics-grid">
        <div class="metric-card">
            <div class="metric-value">100%</div>
            <div class="metric-label">reszponzív megjelenés</div>
        </div>
        <div class="metric-card">
            <div class="metric-value">Kék</div>
            <div class="metric-label">egységes arculati főszín</div>
        </div>
        <div class="metric-card">
            <div class="metric-value">Minden</div>
            <div class="metric-label">View új külsőt kapott</div>
        </div>
        <div class="metric-card">
            <div class="metric-value">0</div>
            <div class="metric-label">backend módosítás</div>
        </div>
    </div>
</section>

<section class="mt-4 feature-grid reveal">
    <article class="feature-item">
        <span class="tag">Szebb navigáció</span>
        <h3 class="mt-3">Újratervezett navbar</h3>
        <p class="text-muted-custom mb-0">Lekerekített, modern, gomb-szerű menüpontokkal és logóval ellátott fejléc.</p>
    </article>
    <article class="feature-item">
        <span class="tag">Kifinomult háttér</span>
        <h3 class="mt-3">Nem egyszínű dizájn</h3>
        <p class="text-muted-custom mb-0">Rétegezett gradientek és lágy fényfoltok adják a prémium, építőipari arculatot.</p>
    </article>
    <article class="feature-item">
        <span class="tag">Jobb CTA-k</span>
        <h3 class="mt-3">Erősebb gombok</h3>
        <p class="text-muted-custom mb-0">Minden fontos kattintható elem látványos gombként jelenik meg.</p>
    </article>
</section>
