@model Lakasdr.Models.Jobs
@{
    ViewData["Title"] = "Munka megtekintése";
}

<section class="hero-card reveal">
    <span class="hero-badge">Projekt részletek</span>
    <h2 class="section-title">Aktuális munka</h2>
    <p class="section-subtitle">A kiválasztott projekthez tartozó alapinformációk.</p>
</section>

<section class="content-card mt-4 reveal">
    <div class="info-grid">
        <div class="info-tile">
            <h4>Azonosító</h4>
            <p class="mb-0">@Model.Id</p>
        </div>
        <div class="info-tile">
            <h4>Munka neve</h4>
            <p class="mb-0">@Model.Name</p>
        </div>
        <div class="info-tile">
            <h4>Leírás</h4>
            <p class="mb-0">@Model.Description</p>
        </div>
    </div>

    <div class="action-row">
        <a asp-action="Munkatars" asp-controller="Home" class="btn btn-primary">Vissza a munkatársakhoz</a>
    </div>
</section>
