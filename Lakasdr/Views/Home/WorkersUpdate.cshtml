@model Lakasdr.Models.Workers

<h2>Dolgozók szerkesztése: </h2>

<form asp-action="WorkersUpdate" method="post">
    <div class="form-group">
        <label asp-for="Id"></label>
        <input asp-for="Id" class="form-control" />
        <span asp-validation-for="Id" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="Name"></label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="WorkId"></label>
        <input asp-for="WorkId" class="form-control" type="number" />
        <span asp-validation-for="WorkId" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="Exp"></label>
        <textarea asp-for="Exp" class="form-control"></textarea>
        <span asp-validation-for="Exp" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Mentés</button>
    <a asp-action="Index" class="btn btn-secondary">Mégse</a>
</form>
