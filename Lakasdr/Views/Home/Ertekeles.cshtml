@model List<Lakasdr.Models.Ertekeles>
@{
    ViewData["Title"] = "Értékelések";
}

<section class="hero-card reveal">
    <span class="hero-badge">Ügyfélvélemények</span>
    <h2 class="section-title">Értékelje cégünket</h2>
    <p class="section-subtitle">Ossza meg tapasztalatát, és segítsen más érdeklődőknek a döntésben.</p>
</section>

<div class="row g-4 mt-1">
    <div class="col-lg-5 reveal">
        <section class="form-card h-100">
            <form method="post" class="inline-form">
                <div>
                    <label for="emailbeker">E-mail cím</label>
                    <input type="email" id="emailbeker" name="email" class="form-control" onblur="Emailcheck()" placeholder="pelda@email.hu" />
                    <span id="emailhiba" class="text-danger"></span>
                </div>

                <input type="hidden" name="pont" id="pont" />

                <div>
                    <label>Csillagos értékelés</label>
                    <div class="rating-stars d-flex flex-wrap gap-2 mt-2">
                        <img src="/rating/feketecsillag.png" id="1cs" onclick="Ertekel(1)" alt="1 csillag" />
                        <img src="/rating/feketecsillag.png" id="2cs" onclick="Ertekel(2)" alt="2 csillag" />
                        <img src="/rating/feketecsillag.png" id="3cs" onclick="Ertekel(3)" alt="3 csillag" />
                        <img src="/rating/feketecsillag.png" id="4cs" onclick="Ertekel(4)" alt="4 csillag" />
                        <img src="/rating/feketecsillag.png" id="5cs" onclick="Ertekel(5)" alt="5 csillag" />
                    </div>
                </div>

                <div>
                    <label for="leiras">Vélemény</label>
                    <textarea name="leiras" id="leiras" rows="5" class="form-control" placeholder="Írja le röviden tapasztalatát..."></textarea>
                </div>

                <div class="action-row">
                    <input type="submit" asp-action="Ertekel" class="btn btn-primary" value="Vélemény elküldése" />
                </div>
            </form>
        </section>
    </div>

    <div class="col-lg-7 reveal">
        <section class="content-card h-100">
            <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
                <div>
                    <span class="tag">Átlagos értékelés</span>
                    <h3 class="mt-3 mb-0">@ViewBag.Atlag / 5</h3>
                </div>
                <img src="/rating/sargacsillag.png" alt="Csillag" style="width:90px;" />
            </div>
            <p class="text-muted-custom mt-3 mb-0">Az itt megjelenő vélemények a rendszerben rögzített visszajelzésekből épülnek fel.</p>
        </section>
    </div>
</div>

<section class="mt-4 card-grid">
    @if (Model.Any())
    {
        @foreach (var item in Model)
        {
            <article class="review-card reveal">
                <div class="review-email">@item.Email</div>
                <p class="my-3">@item.Desc</p>
                <span class="status-chip">@item.Ideje</span>
            </article>
        }
    }
    else
    {
        <div class="empty-card reveal">
            <h4>Még nincs értékelés</h4>
            <p class="mb-0 text-muted-custom">Legyen Ön az első, aki visszajelzést küld.</p>
        </div>
    }
</section>
